#!/bin/sh
# loo — OCaml to Lua compiler (generated by make, do not edit)
ROOT=@ROOT@
RUNTIME=@RUNTIME@

set -e
OUT=""
IN=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o) OUT="$2"; shift 2;;
    *)  [ -z "$IN" ] && IN="$1" || OUT="$1"; shift;;
  esac
done

[ -n "$IN" ] || { echo "Usage: loo <input.ml|input.byte> [output.lua]"; exit 1; }

TMP="$ROOT/_loo_tmp"
mkdir -p "$TMP"

case "$IN" in
  *.ml)   (cd "$ROOT" && ocamlc -g -o "$TMP/_in.byte" "$IN"); BYTE="$TMP/_in.byte";;
  *.byte) BYTE="$IN";;
  *)      echo "loo: expected .ml or .byte file, got $IN"; exit 1;;
esac

cd "$ROOT"
dune exec --root="$ROOT" -- compiler/bin-lua_of_ocaml/main.exe -- "$BYTE" -o "$TMP/_out.lua" 2>&1

if [ -n "$OUT" ]; then
  mv "$TMP/_out.lua" "$OUT"
else
  cat "$TMP/_out.lua"
fi
rm -rf "$TMP"
