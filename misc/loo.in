#!/bin/sh
# loo — OCaml to Lua compiler (generated by make, do not edit)
LOO_BIN="${LOO_BIN:-@LOO_BIN@}"
RUNTIME="${LOO_RUNTIME:-@RUNTIME@}"

set -e
OUT=""
IN=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o) OUT="$2"; shift 2;;
    --runtime) RUNTIME="$2"; shift 2;;
    *)  [ -z "$IN" ] && IN="$1" || OUT="$1"; shift;;
  esac
done

[ -n "$IN" ] || { echo "Usage: loo <input.ml|input.byte> [output.lua]"; exit 1; }

# Resolve paths before potential cd so relative paths still work.
case "$IN"  in /*) ;; *) IN="$(pwd)/$IN";; esac
case "$OUT" in /*|"") ;; *) OUT="$(pwd)/$OUT";; esac

TMPDIR="${TMPDIR:-/tmp}"
TMP="$(mktemp -d "$TMPDIR/loo.XXXXXX")"
trap 'rm -rf "$TMP"' EXIT

case "$IN" in
  *.ml)   ocamlc -g -o "$TMP/_in.byte" "$IN"; BYTE="$TMP/_in.byte";;
  *.byte) BYTE="$IN";;
  *)      echo "loo: expected .ml or .byte file, got $IN"; exit 1;;
esac

"$LOO_BIN" --runtime "$RUNTIME" "$BYTE" -o "$TMP/_out.lua"

if [ -n "$OUT" ]; then
  mv "$TMP/_out.lua" "$OUT"
else
  cat "$TMP/_out.lua"
fi
