#!/bin/sh
# loo — OCaml to Lua compiler
# Usage: ./loo hello.ml              # prints Lua to stdout
#        ./loo hello.ml -o hello.lua # writes hello.lua

set -e
ROOT="$(cd "$(dirname "$0")" && pwd)"
OUT=""
IN=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o) OUT="$2"; shift 2;;
    *)  IN="$1"; shift;;
  esac
done

[ -n "$IN" ] || { echo "Usage: loo <input.ml> [-o output.lua]"; exit 1; }

cd "$ROOT"
TMP="$ROOT/_loo_tmp"
mkdir -p "$TMP"
BYTE="$TMP/_in.byte"

ocamlc -g -o "$BYTE" "$IN"
dune exec --root="$ROOT" -- compiler/bin-lua_of_ocaml/main.exe -- "$BYTE" -o "$TMP/_out.lua" 2>&1

if [ -n "$OUT" ]; then
  mv "$TMP/_out.lua" "$OUT"
else
  cat "$TMP/_out.lua"
fi
rm -rf "$TMP"
