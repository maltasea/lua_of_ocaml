#!/bin/sh
# loo — OCaml to Lua compiler
# Usage: ./loo hello.ml               # .ml: compile with ocamlc, then to Lua
#        ./loo hello.byte             # .byte: skip ocamlc, compile to Lua
#        ./loo hello.ml -o hello.lua  # write to file
#        ./loo hello.ml               # prints Lua to stdout

set -e
ROOT="$(cd "$(dirname "$0")" && pwd)"
OUT=""
IN=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o) OUT="$2"; shift 2;;
    *)  IN="$1"; shift;;
  esac
done

[ -n "$IN" ] || { echo "Usage: loo <input.ml|input.byte> [-o output.lua]"; exit 1; }

cd "$ROOT"
TMP="$ROOT/_loo_tmp"
mkdir -p "$TMP"

case "$IN" in
  *.ml)   ocamlc -g -o "$TMP/_in.byte" "$IN"; BYTE="$TMP/_in.byte";;
  *.byte) BYTE="$IN";;
  *)      echo "looc: expected .ml or .byte file, got $IN"; exit 1;;
esac

dune exec --root="$ROOT" -- compiler/bin-lua_of_ocaml/main.exe -- "$BYTE" -o "$TMP/_out.lua" 2>&1

if [ -n "$OUT" ]; then
  mv "$TMP/_out.lua" "$OUT"
else
  cat "$TMP/_out.lua"
fi
rm -rf "$TMP"
